---
import Loader from "../components/Loader.astro";
import SiteHeader from "../components/sections/SiteHeader.astro";
import ContactModal from "../components/sections/ContactModal.astro";
import Hero from "../components/sections/Hero.astro";
import Ethos from "../components/sections/Ethos.astro";
import FocusIndustries from "../components/sections/FocusIndustries.astro";
import Portfolio from "../components/sections/Portfolio.astro";
import Team from "../components/sections/Team.astro";
import InvestorsFounders from "../components/sections/InvestorsFounders.astro";
import Partners from "../components/sections/Partners.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
---

<html lang="en">
  <head>
    <style is:global>
      @font-face {
        font-family: 'Roc Grotesk';
        font-style: normal;
        font-weight: 900;
        font-display: swap;
        src: url('/assets/roc-grotesk-black.woff2') format('woff2');
      }
      [data-commandoss-brand] {
        transition: width 600ms cubic-bezier(0.65, 0, 0.35, 1);
      }
      .-scrolled [data-commandoss-brand] {
        width: 30px !important;
      }
      .-scrolled [data-commandoss-img] {
        left: 0 !important;
      }
      @media (max-width: 480px) {
        [data-commandoss-brand] {
          width: 120px !important;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        [data-commandoss-brand],
        [data-commandoss-img] {
          transition-duration: 0ms !important;
        }
      }
      /* dvh fallback for older Safari — vh first (always supported), dvh overrides when available */
      .h-dvh {
        height: 100vh;
        height: 100dvh;
      }
      /* While the loader animation is playing, block all scroll & interaction on the rest of the page */
      body.loader-active {
        overflow: hidden !important;
      }
      body.loader-active #smooth-wrapper,
      body.loader-active main,
      body.loader-active section,
      body.loader-active nav {
        pointer-events: none !important;
        user-select: none !important;
      }
      /* Loader itself stays interactive */
      body.loader-active .cmdoss-loader {
        pointer-events: auto !important;
      }

      /* pre-reveal: before Enter click, nothing but the loader (+ its particle container)
	   should be visible. Hides all regular page content; removed when logodots:start fires. */
      html.pre-reveal body > :not(.cmdoss-loader):not(.cmdoss-loader-particles) {
        visibility: hidden !important;
      }
      html.pre-reveal .logo-dots {
        visibility: hidden !important;
      }

      /* Nav starts hidden — revealed by hero timeline alongside the bottom content (same transform). */
      header[data-site-header] {
        opacity: 0;
        transform: translateY(20px);
      }
    </style>
    <script is:inline>
      // Force scroll to top on reload so the hero animation + loader always play from the top.
      // Browsers default to restoring the previous scroll position; override that.
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.scrollTo(0, 0);
      window.addEventListener("beforeunload", () => window.scrollTo(0, 0));
      // Enable loader lock + pre-reveal ASAP (before any CSS paints)
      document.documentElement.classList.add("loader-active", "pre-reveal");
      document.addEventListener("DOMContentLoaded", () => {
        document.body.classList.add("loader-active");
      });
      // When Enter is clicked, the Loader dispatches logodots:start → reveal page content
      // (but keep loader-active so interaction is still blocked until C is formed)
      window.addEventListener(
        "logodots:start",
        () => {
          document.documentElement.classList.remove("pre-reveal");
        },
        { once: true },
      );
      // When WebGL intro fully done, release interaction lock
      window.addEventListener(
        "logodots:ready",
        () => {
          document.body.classList.remove("loader-active");
          document.documentElement.classList.remove("loader-active");
        },
        { once: true },
      );
    </script>
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="origin-when-cross-origin" />

    <link rel="preload" href="/assets/main.min.css" as="style" />
    <link rel="stylesheet" href="/assets/main.min.css" />
    <link rel="stylesheet" href="/palette.css" />

    <script is:inline src="/assets/three.min.js" defer></script>
    <script is:inline src="/assets/swiper.min.js" defer></script>
    <script is:inline src="/assets/gsap.min.js" defer></script>
    <script is:inline src="/assets/main.min.js" defer></script>

    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />
    <link rel="shortcut icon" href="/favicons/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/favicons/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="CommandOSS" />
    <meta name="application-name" content="CommandOSS" />
    <meta name="msapplication-TileColor" content="#111111" />
    <meta name="theme-color" content="#111111" />

    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

    <script
