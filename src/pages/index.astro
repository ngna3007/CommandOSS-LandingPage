    <meta content="CommandOSS" property="og:site_name" />
    <meta content="website" property="og:type" />
    <meta content="https://commandoss.com/" property="og:url" />
    <meta content="CommandOSS — Building on Sui at Full Speed" property="og:title" />
    <meta
      content="CommandOSS is Mysten Labs' engineering unit in Vietnam, shipping breakthrough open-source products on Sui — from zkLogin to robots."
      property="og:description"
    />
    <meta content="https://command-oss-landing-page.vercel.app/assets/og-image.png" property="og:image" />
    <meta content="1200" property="og:image:width" />
    <meta content="630" property="og:image:height" />
    <meta content="CommandOSS logo" property="og:image:alt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@0xCommandOSS" />
    <meta name="twitter:site" content="@0xCommandOSS" />
    <meta name="twitter:title" content="CommandOSS — Building on Sui at Full Speed" />
    <meta
