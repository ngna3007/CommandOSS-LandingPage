    <link rel="stylesheet" href="/assets/phone-country.css" />
  </head>
  <body class="bg-rich-carbon text-neural-fog font-roc-grotesk">
    <Loader />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-8X176434G8"></script>

    <div
      x-data="dragCursor()"
      class="p3-mono bg-rich-carbon text-off-white pointer-events-none fixed top-0 left-0 z-1000 flex h-[32px] items-center justify-center overflow-hidden rounded-full px-[16px] uppercase opacity-0"
    >
      <div class="relative flex w-full flex-col overflow-hidden text-center" data-text-container>
        <span class="whitespace-nowrap">Drag</span>
        <span class="absolute top-full w-full whitespace-nowrap" aria-hidden="true">
          Go to website
        </span>
      </div>
    </div>
    <div
      x-data="viewCursor()"
      class="p3-mono bg-off-white text-rich-carbon pointer-events-none fixed z-50 flex h-[32px] -translate-x-1/2 -translate-y-1/2 items-center justify-center overflow-hidden rounded-full px-[16px] uppercase opacity-0"
    >
      <div class="relative flex w-full flex-col overflow-hidden text-center" data-text-container>
        <span class="whitespace-nowrap">View</span>
        <span class="absolute top-full w-full whitespace-nowrap" aria-hidden="true"> Hide </span>
      </div>
    </div>

    <div id="smooth-wrapper">
      <a class="skip-link" href="#main">Skip to content</a>

      <SiteHeader />

      <ContactModal />
      <div id="smooth-content">
        <main id="main" tabindex="-1">
          <div id="main" tabindex="-1"></div>
          <Hero />

          <Ethos />

          <div class="bg-neural-fog text-rich-carbon">
            <FocusIndustries />

            <Portfolio />
          </div>

          <div class="bg-rich-carbon -mt-[20px] overflow-hidden rounded-t-[20px]">
            <Team />

            <InvestorsFounders />
            <Partners />

            <SiteFooter />
          </div>
        </main>
      </div>
    </div>
