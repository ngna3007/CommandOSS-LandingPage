---
interface Props {
  src?: string;
  sampleStep?: number;
  mode?: "tube" | "logo";
  color?: number | string;
  rotate?: number;
}
const {
  src = "/logo.svg",
  sampleStep = 8,
  mode = "logo",
  color,
  rotate = 0,
} = Astro.props;
const colorAttr = color === undefined ? undefined : typeof color === "number" ? `0x${color.toString(16)}` : String(color);
---

<div
  class="logo-dots"
  data-src={src}
  data-step={sampleStep}
  data-mode={mode}
  data-color={colorAttr}
  data-rotate={rotate}
>
  <canvas></canvas>
</div>

<style>
  .logo-dots {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
  .logo-dots canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";
  import { gsap } from "gsap";

  // === OG constants — verbatim from main.min.js ===
  const Li = 0.01,
    ji = 0.015,
    Ni = 0.02;
  const Hi = { x: 0, y: 0, z: 50 };
  const $i = 60;
  const Di = {
    radius: 1.5,
    tubularSegments: 60,
    radialSegments: 60,
    arcHeight: 0,
    arcLength: 22,
    position: { x: 4.9, y: -1.6, z: 36 },
    rotation: { x: 0, y: -117, z: 11 },
    mobilePosition: { x: 4.9, y: -1.6, z: 34 },
    mobileRotation: { x: 0, y: -117, z: 11 },
  };
  // Fi = dot color — clean cyan accent, high contrast on rich-carbon, distinct from brand blue.
  // Vi = scene bg + fog color — near-black with subtle blue undertone (cooler than OG #111111).
  const Fi = 0x22d3ee,
    Wi = 0.4,
    Bi = 170,
    qi = 0,
    Ui = 15,
    Vi = 0x0a0e1a;

  // OG Xi / Gi / Ki helpers — verbatim
  function Xi(t: number, e: number, n: number, i: boolean) {
    const r = i ? Math.cos : Math.sin;
    return 0.5 * Math.sin(r(t + e * n) * Math.PI);
  }
  function Gi(t: number, e: number, n: number, i: number) {
    return {
      x: Xi(t, e, Li, false),
      y: Xi(t, n, ji, true),
      z: Xi(t, i, Ni, false),
    };
  }
  function Ki(
    out: Float32Array,
    idx: number,
    orig: Float32Array,
    off: { x: number; y: number; z: number },
    intensity: number,
    deflection: Float32Array,
    isTouch: boolean,
  ) {
    out[idx] = orig[idx] + off.x * intensity + (isTouch ? 0 : deflection[idx]);
    out[idx + 1] = orig[idx + 1] + off.y * intensity + (isTouch ? 0 : deflection[idx + 1]);
    out[idx + 2] = orig[idx + 2] + off.z * intensity + (isTouch ? 0 : deflection[idx + 2]);
  }

  const deg = (d: number) => (d * Math.PI) / 180;

  type DotsRoot = HTMLElement & { __disposed?: boolean };

  // Build geometry — either OG tube or logo sampled from SVG
  async function buildTubeGeometry(): Promise<{ positions: Float32Array; count: number }> {
    const curve = new THREE.QuadraticBezierCurve3(
      new THREE.Vector3(-Di.arcLength / 2, 0, 0),
      new THREE.Vector3(0, Di.arcHeight, 0),
      new THREE.Vector3(Di.arcLength / 2, 0, 0),
    );
    const tube = new THREE.TubeGeometry(
      curve,
      Di.tubularSegments,
      Di.radius,
      Di.radialSegments,
      false,
    );
    const positions = (tube.attributes.position.array as Float32Array).slice();
    tube.dispose();
    return { positions, count: positions.length / 3 };
  }

  async function buildLogoGeometry(svgUrl: string, step: number) {
    const res = await fetch(svgUrl);
    const svgText = await res.text();
    const blob = new Blob([svgText], { type: "image/svg+xml" });
    const url = URL.createObjectURL(blob);
    const img = new Image();
    img.decoding = "async";
    img.src = url;
    await img.decode();

    const rasterSize = 512;
    const off = document.createElement("canvas");
    off.width = rasterSize;
    off.height = rasterSize;
    const ctx = off.getContext("2d", { willReadFrequently: true })!;
    const scale = Math.min(rasterSize / img.width, rasterSize / img.height);
    const w = img.width * scale;
    const h = img.height * scale;
    ctx.drawImage(img, (rasterSize - w) / 2, (rasterSize - h) / 2, w, h);
    URL.revokeObjectURL(url);

    const { data } = ctx.getImageData(0, 0, rasterSize, rasterSize);
    const pixels: Array<[number, number]> = [];
    for (let y = 0; y < rasterSize; y += step) {
      for (let x = 0; x < rasterSize; x += step) {
        if (data[(y * rasterSize + x) * 4 + 3] > 128) pixels.push([x, y]);
      }
    }
    if (!pixels.length) throw new Error("No pixels sampled");

    let minX = Infinity,
      minY = Infinity,
      maxX = -Infinity,
      maxY = -Infinity;
    for (const [x, y] of pixels) {
      if (x < minX) minX = x;
      if (x > maxX) maxX = x;
      if (y < minY) minY = y;
      if (y > maxY) maxY = y;
    }
    const cx = (minX + maxX) / 2;
    const cy = (minY + maxY) / 2;
    // Viewport-responsive scale: smaller on mobile, clamped on ultrawide.
    // 0.22 at 360px → 0.29 at 1280px → 0.33 at 1920px+
    const vw = Math.max(320, Math.min(1920, window.innerWidth));
    const scaleFactor = 0.22 + ((vw - 360) / (1920 - 360)) * 0.11;
    const pxToWorld = (Di.arcLength * scaleFactor) / Math.max(maxX - minX, maxY - minY);

    const positions = new Float32Array(pixels.length * 3);
    for (let i = 0; i < pixels.length; i++) {
      const [px, py] = pixels[i];
      positions[i * 3] = (px - cx) * pxToWorld;
      positions[i * 3 + 1] = -(py - cy) * pxToWorld;
      positions[i * 3 + 2] = 0;
    }
    return { positions, count: pixels.length };
  }

  function makeMaterial(colorHex: number = Fi) {
    return new THREE.ShaderMaterial({
      uniforms: THREE.UniformsUtils.merge([
        THREE.UniformsLib.fog,
        {
          color: { value: new THREE.Color(colorHex) },
          size: { value: Wi },
          sizeAttenuation: { value: Bi },
        },
      ]),
      vertexShader: `
        uniform float size;
        uniform float sizeAttenuation;
        #include <fog_pars_vertex>
        void main() {
          vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = size * (sizeAttenuation / -mvPosition.z);
          gl_Position = projectionMatrix * mvPosition;
          #include <fog_vertex>
        }
      `,
      fragmentShader: `
        uniform vec3 color;
        #include <fog_pars_fragment>
        void main() {
          vec2 center = gl_PointCoord - vec2(0.5);
          if (dot(center, center) > 0.25) discard;
          gl_FragColor = vec4(color, 1.0);
          #include <fog_fragment>
        }
      `,
      fog: true,
      transparent: false,
    });
  }

  // Fog-less, alpha-driven variant for tunnel ghost layers.
  // Shares the same geometry as the main logo but renders at variable z + opacity.
  function makeTunnelMaterial(colorHex: number = Fi) {
    return new THREE.ShaderMaterial({
      uniforms: {
        color: { value: new THREE.Color(colorHex) },
        size: { value: Wi },
        sizeAttenuation: { value: Bi },
        alpha: { value: 0 },
      },
      vertexShader: `
        uniform float size;
        uniform float sizeAttenuation;
        void main() {
          vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = size * (sizeAttenuation / -mvPosition.z);
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: `
        uniform vec3 color;
        uniform float alpha;
        void main() {
          vec2 center = gl_PointCoord - vec2(0.5);
          if (dot(center, center) > 0.25) discard;
          gl_FragColor = vec4(color, alpha);
        }
      `,
      transparent: true,
      depthWrite: false,
    });
  }

  async function init(root: DotsRoot) {
    const canvas = root.querySelector("canvas") as HTMLCanvasElement;
    const src = root.dataset.src!;
    const step = Number(root.dataset.step) || 4;
    const mode = root.dataset.mode || "logo";
    const colorRaw = root.dataset.color;
    const dotColor = colorRaw ? (colorRaw.startsWith("0x") ? parseInt(colorRaw, 16) : parseInt(colorRaw)) : Fi;
    const rotateZdeg = Number(root.dataset.rotate) || 0;

    const isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Scene setup — matches OG tr()
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: false,
      powerPreference: "high-performance",
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(Vi, 1);

    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(Vi, qi, Ui);

    const camera = new THREE.PerspectiveCamera($i, 1, 0.1, 1000);
    camera.position.set(Hi.x, Hi.y, Hi.z);

    const material = makeMaterial(dotColor);
    const geometry = new THREE.BufferGeometry();
    const points = new THREE.Points(geometry, material);

    function applyTransform() {
      const mobile = window.innerWidth < 768;
      const p = mobile ? Di.mobilePosition : Di.position;
      // For the logo, keep OG position but drop the -117° Y rotation (was calibrated for a
      // horizontal arc, not a square logo — it made the "C" edge-on).
      // Small tilt keeps the 3D feel without losing readability.
      if (mode === "tube") {
        const r = mobile ? Di.mobileRotation : Di.rotation;
        points.rotation.set(deg(r.x), deg(r.y), deg(r.z));
      } else {
        // Additional CW rotation on screen = negative Z in three.js (right-handed, Y-up).
        points.rotation.set(deg(-6), 0, deg(-4 - rotateZdeg));
      }
      // Center horizontally and pull closer to camera. OG z=36 worked for the tube because
      // its arc extended toward the camera (parts at z~45). A flat logo at z=36 sits entirely
      // inside the fog (far=15, camera at z=50 → dot is 14 units away, almost fully fogged).
      if (mode === "tube") {
        points.position.set(p.x, p.y, p.z);
      } else {
        points.position.set(0, 0.4, 42);
      }
    }
    applyTransform();
    scene.add(points);

    // === Infinite tunnel layers (logo mode only) ===
    // Ghost copies of the "C" behind the main dots. Each layer loops along the z-axis
    // from deep → front, fading in/out with a sin-curve alpha. Phases are offset so
    // the layers are spaced evenly along the tunnel.
    const TUNNEL_LAYERS = 3;
    const TUNNEL_LOOP_SEC = 6;
    const TUNNEL_Z_DEPTH = 14; // how far behind main the tunnel extends
    const TUNNEL_ALPHA_PEAK = 0.22;
    const tunnelLayers: Array<{
      points: THREE.Points;
      mat: THREE.ShaderMaterial;
      phaseOffset: number;
    }> = [];
    const tunnelEnabled = mode === "logo" && !prefersReducedMotion;

    // Build geometry
    let geom: { positions: Float32Array; count: number };
    try {
      geom = mode === "tube" ? await buildTubeGeometry() : await buildLogoGeometry(src, step);
    } catch (err) {
      console.error("[LogoDots] geometry build failed:", err);
      return;
    }
    if (root.__disposed) return;

    const originalPositions = geom.positions;
    const livePositions = new Float32Array(originalPositions.length);
    livePositions.set(originalPositions);
    geometry.setAttribute("position", new THREE.BufferAttribute(livePositions, 3));
    (geometry.attributes.position as THREE.BufferAttribute).setUsage(THREE.DynamicDrawUsage);
    geometry.computeBoundingSphere();
    console.log("[LogoDots]", mode, geom.count, "dots");

    if (tunnelEnabled) {
      for (let i = 0; i < TUNNEL_LAYERS; i++) {
        const mat = makeTunnelMaterial(dotColor);
        const pts = new THREE.Points(geometry, mat);
        pts.rotation.copy(points.rotation);
        pts.position.copy(points.position);
        scene.add(pts);
        tunnelLayers.push({ points: pts, mat, phaseOffset: i / TUNNEL_LAYERS });
      }
    }

    // Mouse-deflection buffers — OG Zi()
    const deflectionTarget = new Float32Array(originalPositions.length);
    const deflectionCurrent = new Float32Array(originalPositions.length);
    const mouse = { x: 0, y: 0 };
    const tmpA = new THREE.Vector3();
    const tmpB = new THREE.Vector3();

    // Fly-in offset: each vertex gets a random direction × big initial distance.
    // Intensity eases 1→0 during intro so dots appear to stream in from off-screen toward their home.
    const flyInDirs = new Float32Array(originalPositions.length);
    for (let g = 0; g < originalPositions.length; g += 3) {
      // Random direction on a unit sphere (uniformly distributed)
      const u = Math.random(),
        v = Math.random();
      const theta = 2 * Math.PI * u;
      const phi = Math.acos(2 * v - 1);
      flyInDirs[g] = Math.sin(phi) * Math.cos(theta);
      flyInDirs[g + 1] = Math.sin(phi) * Math.sin(theta);
      flyInDirs[g + 2] = Math.cos(phi);
    }
    // Distance far enough that dots start well outside the viewport at camera z=50 with fov 60°
    const FLY_IN_DISTANCE = 80;
    let flyInStrength = 1; // eases 1→0 during intro

    // OG wave intensity curve: starts huge (30), animates down to 0.02 over 2s, then spatialBlend 0→1
    let waveIntensity = 30;
    let spatialBlend = 0;
    let introComplete = false;
    let tunnelVisibility = 0;
    let tunnelTime = 0;
    let lastNow = performance.now();

    function startIntro() {
      // Only skip the intro for users who've asked for reduced motion.
      // Touch-capable devices (phones, tablets, touchscreen laptops) still see it.
      if (prefersReducedMotion) {
        waveIntensity = 0.02;
        spatialBlend = 1;
        flyInStrength = 0;
        introComplete = true;
        tunnelVisibility = 1;
        window.dispatchEvent(new CustomEvent("logodots:ready"));
        return;
      }
      // Fly-in: dots stream from off-screen to their home position over 1.4s
      gsap.to(
        { v: 1 },
        {
          v: 0,
          duration: 1.4,
          ease: "power3.out",
          onUpdate() {
            flyInStrength = (this.targets()[0] as any).v;
          },
        },
      );
      gsap.to(
        { v: waveIntensity },
        {
          v: 0.02,
          duration: 2,
          ease: "power3.inOut",
          onUpdate() {
            waveIntensity = (this.targets()[0] as any).v;
          },
          onComplete() {
            introComplete = true;
            gsap.to(
              { v: 0 },
              {
                v: 1,
                duration: 1.5,
                ease: "power2.inOut",
                onUpdate() {
                  spatialBlend = (this.targets()[0] as any).v;
                },
                onComplete() {
                  window.dispatchEvent(new CustomEvent("logodots:ready"));
                },
              },
            );
            gsap.to(
              { v: 0 },
              {
                v: 1,
                duration: 2,
                ease: "power2.inOut",
                onUpdate() {
                  tunnelVisibility = (this.targets()[0] as any).v;
                },
              },
            );
          },
        },
      );
    }

    // Wait for loader to finish before starting the intro.
    // If the loader never exists (e.g. the component is reused elsewhere), start after a short delay.
    let introStarted = false;
    function triggerIntro() {
      if (introStarted) return;
      introStarted = true;
      startIntro();
    }
    window.addEventListener("logodots:start", triggerIntro, { once: true });
    // If the loader has already dispatched the event before this component mounted, catch it.
    if ((window as any).__logodotsStartFired) triggerIntro();

    function onResize() {
      const w = root.clientWidth || window.innerWidth;
      const h = root.clientHeight || window.innerHeight;
      if (w === 0 || h === 0) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      applyTransform();
    }
    onResize();
    window.addEventListener("resize", onResize);
    const ro = typeof ResizeObserver !== "undefined" ? new ResizeObserver(onResize) : null;
    ro?.observe(root);

    function onMouseMove(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }
    window.addEventListener("pointermove", onMouseMove);

    // Animation loop — mirrors OG updateWavePositions
    let time = 0;
    let rafId = 0;
    const tick = () => {
      rafId = requestAnimationFrame(tick);
      time += 0.01;

      // Mouse-driven deflection (only after intro, only desktop)
      if (introComplete && !isTouch) {
        points.updateMatrixWorld();
        const matrix = points.matrixWorld;
        const canvasW = canvas.width / renderer.getPixelRatio();
        const canvasH = canvas.height / renderer.getPixelRatio();

        for (let p = 0; p < geom.count; p++) {
          const f = 3 * p;
          tmpA.set(originalPositions[f], originalPositions[f + 1], originalPositions[f + 2]);
          tmpA.applyMatrix4(matrix);
          tmpB.copy(tmpA).project(camera);
          const sx = (0.5 * tmpB.x + 0.5) * canvasW;
          const sy = (0.5 * -tmpB.y + 0.5) * canvasH;
          const dx = sx - mouse.x;
          const dy = sy - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 125) {
            const w = 1 - dist / 125;
            const a = Math.atan2(dy, dx);
            deflectionTarget[f] = -Math.cos(a) * w * 1.5;
            deflectionTarget[f + 1] = -Math.sin(a) * w * 1.5;
            deflectionTarget[f + 2] = 1.5 * w * 0.5;
          } else {
            deflectionTarget[f] = 0;
            deflectionTarget[f + 1] = 0;
            deflectionTarget[f + 2] = 0;
          }
          // Smooth lerp
          deflectionCurrent[f] += 0.1 * (deflectionTarget[f] - deflectionCurrent[f]);
          deflectionCurrent[f + 1] += 0.1 * (deflectionTarget[f + 1] - deflectionCurrent[f + 1]);
          deflectionCurrent[f + 2] += 0.1 * (deflectionTarget[f + 2] - deflectionCurrent[f + 2]);
        }
      }

      // Wave displacement + fly-in offset
      const flyScale = FLY_IN_DISTANCE * flyInStrength;
      for (let g = 0; g < livePositions.length; g += 3) {
        const v = originalPositions[g];
        const y = originalPositions[g + 1];
        const b = originalPositions[g + 2];
        const wIdx = Gi(time, g, g, g);
        const wPos = Gi(time, v, y, b);
        const blended = {
          x: wIdx.x * (1 - spatialBlend) + wPos.x * spatialBlend,
          y: wIdx.y * (1 - spatialBlend) + wPos.y * spatialBlend,
          z: wIdx.z * (1 - spatialBlend) + wPos.z * spatialBlend,
        };
        Ki(livePositions, g, originalPositions, blended, waveIntensity, deflectionCurrent, isTouch);
        // Additive fly-in displacement — each dot enters from its random direction
        if (flyScale > 0.01) {
          livePositions[g] += flyInDirs[g] * flyScale;
          livePositions[g + 1] += flyInDirs[g + 1] * flyScale;
          livePositions[g + 2] += flyInDirs[g + 2] * flyScale;
        }
      }
      (geometry.attributes.position as THREE.BufferAttribute).needsUpdate = true;

      // Tunnel layers: each loops z = [main.z - TUNNEL_Z_DEPTH → main.z] with sin-curve alpha.
      if (tunnelLayers.length > 0 && tunnelVisibility > 0.001) {
        const now = performance.now();
        const dt = Math.min(0.05, (now - lastNow) / 1000);
        lastNow = now;
        tunnelTime = (tunnelTime + dt / TUNNEL_LOOP_SEC) % 1;
        const mainZ = points.position.z;
        for (const { points: p, mat, phaseOffset } of tunnelLayers) {
          const phase = (tunnelTime + phaseOffset) % 1;
          p.position.x = points.position.x;
          p.position.y = points.position.y;
          p.position.z = mainZ - TUNNEL_Z_DEPTH + phase * TUNNEL_Z_DEPTH;
          p.rotation.copy(points.rotation);
          const a = TUNNEL_ALPHA_PEAK * Math.sin(phase * Math.PI) * tunnelVisibility;
          mat.uniforms.alpha.value = a;
        }
      } else {
        lastNow = performance.now();
      }

      renderer.render(scene, camera);
    };
    tick();

    const cleanup = () => {
      root.__disposed = true;
      cancelAnimationFrame(rafId);
      window.removeEventListener("resize", onResize);
      window.removeEventListener("pointermove", onMouseMove);
      ro?.disconnect();
      for (const { mat } of tunnelLayers) mat.dispose();
      geometry.dispose();
      material.dispose();
      renderer.dispose();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }

  document.querySelectorAll<HTMLElement>(".logo-dots").forEach((el) => init(el as DotsRoot));
</script>
