---

<section id="team" class="relative z-1 pt-[40px] pb-[80px] md:pb-[160px]">
  <div class="container">
    <div class="p2-mono mb-[80px] flex items-center justify-between md:mb-0">
      <span aria-hidden="true">The people in the house</span>
      <h2>The people in the house</h2>
      <span class="hidden md:block" aria-hidden="true">The people in the house</span>
    </div>
    <figure class="mx-auto mt-[32px] w-full max-w-[1280px] md:mt-[80px]">
      <picture>
        <source srcset="/assets/people-in-the-house.avif" type="image/avif" />
        <source srcset="/assets/people-in-the-house.webp" type="image/webp" />
        <img
          src="/assets/people-in-the-house.jpg"
          alt="CommandOSS team in Ho Chi Minh City"
          loading="lazy"
          decoding="async"
          class="aspect-video w-full rounded-[20px] object-cover"
        />
      </picture>
    </figure>
    <div class="mt-[64px] flex flex-col items-center text-center md:mt-[80px]">
      <p class="p2-mono text-off-white/60 mx-auto max-w-[438px] text-balance">
        Engineers and researchers in Ho Chi Minh City, building with the Mysten Labs core team and
        contributing back to the Sui ecosystem.
      </p>
    </div>
  </div>
</section>
