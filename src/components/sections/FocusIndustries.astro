---
---

<div id="focus-industries" class="relative isolate -mt-[2px] overflow-hidden">
  <div class="absolute inset-0 -z-1 size-full" x-data="focusIndustries">
    <canvas
      x-ref="canvas"
      class="size-full"
      style="mask-image: linear-gradient(0deg, transparent 0%, black 20%, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(0deg, transparent 0%, black 20%, black 80%, transparent 100%);"
    ></canvas>
  </div>

  <div
    class="from-neural-fog to-neural-fog pointer-events-none absolute inset-0 z-1 hidden h-screen w-full bg-linear-to-b via-transparent md:block"
    x-data="{
					init() {
						const mm = gsap.matchMedia();

						mm.add('(min-width: 768px)', () => {
							ScrollTrigger.create({
								trigger: '#focus-industries',
								start: 'top top',
								end: 'bottom top',
								pin: this.$el,
								pinSpacing: false,
								invalidateOnRefresh: true,
							});
						});
					}
				}"
  >
  </div>

  <section
    id="focus"
    class="flex h-dvh items-center overflow-hidden"
    x-data="{
		init() {
			this.$nextTick(() => {
				const tl = gsap.timeline({
					scrollTrigger: {
						trigger: this.$el,
						start: 'top 50%',
					}
				});
				tl.from([this.$refs.preheading, this.$refs.heading, this.$refs.description], {
					opacity: 0,
					y: 64,
					ease: 'power4.inOut',
					duration: 1.2,
				})
			})
		}
	}"
  >
    <div class="container text-center">
      <div class="mx-auto flex max-w-[895px] flex-col items-center gap-[30px]">
        <div class="flex flex-col gap-[12px]">
          <h2 class="p1-mono" x-ref="preheading">Our focus</h2>
          <h3 class="h2 uppercase" x-ref="heading">
            Built on Sui. Shipped to the world.
          </h3>
        </div>
        <p class="p3 md:p1 max-w-[305px] md:max-w-[550px]" x-ref="description">
          Built with Sui, Walrus, Seal, Enoki, and Nautilus. We ship products across the
          Mysten stack — for governments, institutions, and the builders coming next.
        </p>
      </div>
    </div>
  </section>

  <section
    id="industries"
    class="-mt-px min-h-dvh py-[40px] md:py-[100px]"
    x-data="{
		init() {
			gsap.from(this.$refs.content, {
				opacity: 0,
				y: 80,
				duration: 1.2,
				ease: 'power4.inOut',
				scrollTrigger: {
					trigger: this.$el,
					start: 'top 60%',
				}
			})
		}
	}"
  >
    <div
      class="relative container"
      x-ref="content"
      x-data="{
			links: [],
			activeLink: null,
			isMobile: false,
			width: 0,
			height: 0,
			offsetLeft: 0,
			offsetTop: 0,
			animationFrameId: null,
			animationStartTime: null,
			animationDuration: 300,
			updateDimensions(link) {
				const list = this.$refs.list;
				this.width = link.offsetWidth;
				this.offsetLeft = list.offsetLeft + link.offsetLeft;
				this.offsetTop = list.offsetTop + link.offsetTop + 30;
				this.height = link.offsetHeight - 60;
			},
			animateUpdate(link) {
				const now = Date.now();
				const elapsed = now - this.animationStartTime;

				this.updateDimensions(link);

				if (elapsed < this.animationDuration) {
					this.animationFrameId = requestAnimationFrame(() => this.animateUpdate(link));
				} else {
					this.animationFrameId = null;
				}
			},
			setActive(index) {
				this.activeLink = index - 1;

				if (this.animationFrameId) {
					cancelAnimationFrame(this.animationFrameId);
				}

				setTimeout(() => {
					const link = this.links[this.activeLink];
					if (link) {
						this.animationStartTime = Date.now();
						this.animateUpdate(link);
					}
				}, 200);
			},
			handleHover(index) {
				if (!this.isMobile) {
					this.setActive(index);
				}
			},
			handleClick(index) {
				if (this.activeLink === index - 1) {
					this.clearActive();
				} else {
					this.setActive(index);
				}
			},
			clearActive() {
				this.activeLink = null;
				if (this.animationFrameId) {
					cancelAnimationFrame(this.animationFrameId);
					this.animationFrameId = null;
				}
			},
			handleMouseLeave() {
				if (!this.isMobile) {
					this.clearActive();
				}
			},
			checkMobile() {
				this.isMobile = window.innerWidth < 768;
			},
			init() {
				this.$nextTick(() => {
					this.links = this.$refs.list.querySelectorAll('li');
					const list = this.$refs.list;
					const firstLink = this.links[0];
					this.width = firstLink.offsetWidth;
					this.height = firstLink.offsetHeight;
					this.offsetLeft	= list.offsetLeft + firstLink.offsetLeft;
					this.offsetTop	= list.offsetTop + firstLink.offsetTop + 30;
				});

				this.checkMobile();
				if (this.isMobile) {
					this.setActive(1);
				}
			}
		}"
      @resize.window="checkMobile(); isMobile ? setActive(1) : clearActive()"
    >
      <ul class="relative isolate flex flex-col items-center text-center" x-ref="list">
        <li
          class="group grid grid-rows-[auto_0fr] px-[40px] py-[10px] text-center transition-[grid-template-rows,padding] duration-500 ease-(--easing) data-active:grid-rows-[auto_1fr] data-active:py-[60px] motion-reduce:duration-[0ms] md:py-0"
          :data-active="activeLink === 0"
          @mouseenter="handleHover(1)"
          @mouseleave="handleMouseLeave()"
        >
          <button
            class="relative isolate w-full overflow-hidden md:cursor-default"
            @click="handleClick(1)"
            :aria-expanded="(activeLink === 0).toString()"
            aria-controls="industry-content-1"
          >
            <h3
              class="h4 min-[360px]:h-vw uppercase transition-transform duration-500 ease-(--easing) group-data-active:-translate-y-full motion-reduce:duration-[0ms]"
            >
              Advanced Mobility
            </h3>
            <span
              aria-hidden="true"
              class="h4 min-[360px]:h-vw absolute inset-0 translate-y-full uppercase transition-transform duration-500 ease-(--easing) group-data-active:translate-y-0 motion-reduce:duration-[0ms]"
            >
              Advanced Mobility
            </span>
          </button>
          <div class="flex justify-center overflow-hidden" id="industry-content-1">
            <p
              class="p2 max-w-[430px] pt-[4px] ease-(--easing) motion-reduce:duration-[0ms]"
            >
              Autonomous aviation, smart transit, and sustainable transport reshaping
              movement.
            </p>
          </div>
        </li>
        <li
          class="group grid grid-rows-[auto_0fr] px-[40px] py-[10px] text-center transition-[grid-template-rows,padding] duration-500 ease-(--easing) data-active:grid-rows-[auto_1fr] data-active:py-[60px] motion-reduce:duration-[0ms] md:py-0"
          :data-active="activeLink === 1"
          @mouseenter="handleHover(2)"
          @mouseleave="handleMouseLeave()"
        >
          <button
            class="relative isolate w-full overflow-hidden md:cursor-default"
            @click="handleClick(2)"
            :aria-expanded="(activeLink === 1).toString()"
            aria-controls="industry-content-2"
          >
            <h3
              class="h4 min-[360px]:h-vw uppercase transition-transform duration-500 ease-(--easing) group-data-active:-translate-y-full motion-reduce:duration-[0ms]"
            >
              Artificial Intelligence
            </h3>
            <span
              aria-hidden="true"
              class="h4 min-[360px]:h-vw absolute inset-0 translate-y-full uppercase transition-transform duration-500 ease-(--easing) group-data-active:translate-y-0 motion-reduce:duration-[0ms]"
            >
              Artificial Intelligence
            </span>
          </button>
          <div class="flex justify-center overflow-hidden" id="industry-content-2">
            <p
              class="p2 max-w-[430px] pt-[4px] ease-(--easing) motion-reduce:duration-[0ms]"
            >
              Transforming industries through data, automation, and intelligence at
              scale.
            </p>
          </div>
        </li>
        <li
          class="group grid grid-rows-[auto_0fr] px-[40px] py-[10px] text-center transition-[grid-template-rows,padding] duration-500 ease-(--easing) data-active:grid-rows-[auto_1fr] data-active:py-[60px] motion-reduce:duration-[0ms] md:py-0"
          :data-active="activeLink === 2"
