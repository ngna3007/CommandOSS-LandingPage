---
---

<footer id="footer" x-data="footer">
  <div class="container px-0!">
    <div class="bg-rich-carbon relative grid lg:grid-cols-2">
      <canvas class="hidden size-full lg:block" x-ref="canvas"></canvas>
      <div
        class="bg-infrared text-rich-carbon grid w-full grid-cols-2 gap-[12px] gap-y-[60px] rounded-t-[20px] px-[10px] pt-[30px] pb-[10px] md:min-h-[666px] md:gap-[32px] md:gap-y-[210px] md:rounded-bl-[20px] md:pt-[40px] md:pb-[30px] lg:px-[24px] xl:px-[40px]"
      >
        <div class="flex w-full flex-col items-start justify-start gap-[12px]">
          <h2 class="h6 uppercase">Build on Sui. Build with us.</h2>
          <p class="p2-mono mb-auto">
            Protocol teams, partners, and engineers with work to ship on Sui — get in
            touch.
          </p>
          <div class="mt-[18px] w-full max-w-[200px] md:mt-0 [&_button]:w-full">
            <button
              class="group/button hover:animate-glitch-hover relative isolate motion-reduce:hover:animate-none"
              data-theme="dark"
              aria-label=""
              @click="$dispatch('contact-modal:open', '#contact')"
              x-data
            >
              <div class="flex h-[40px] items-center justify-center px-[20px]">
                <div
                  class="group-data-[theme=light]/button:bg-neural-fog group-data-[theme=dark]/button:bg-rich-carbon motion-reduce:blur-0 button--dot size-[10px] -translate-x-[24px] rounded-[3px] opacity-0 blur-[20px] transition-all duration-400 ease-(--easing) group-hover/button:-translate-x-[5px] group-hover/button:opacity-100 group-hover/button:blur-[0px] group-active/button:-translate-x-[5px] group-active/button:opacity-100 group-active/button:blur-[0px] motion-reduce:hidden motion-reduce:translate-x-0 motion-reduce:opacity-0 motion-reduce:group-hover/button:translate-x-0 motion-reduce:group-hover/button:opacity-0"
                >
                </div>
                <div
                  class="p2-mono group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon relative isolate flex -translate-x-[5px] overflow-hidden transition-transform duration-400 ease-(--easing) group-hover/button:translate-x-[5px] group-active/button:translate-x-[5px] motion-reduce:translate-x-0 motion-reduce:group-hover/button:translate-x-0"
                >
                  <span
                    class="transition-transform duration-400 ease-(--easing) group-hover/button:-translate-y-full group-active/button:-translate-y-full motion-reduce:translate-y-0 motion-reduce:group-hover/button:translate-y-0"
                  >
                    Contact Us
                  </span>
                  <span
                    class="absolute inset-0 translate-y-full transition-transform duration-400 ease-(--easing) group-hover/button:translate-y-0 group-active/button:translate-y-0 motion-reduce:hidden"
                    aria-hidden="true"
                  >
                    Contact Us
                  </span>
                </div>
              </div>
              <svg
                class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
                width="10"
                height="10"
                viewBox="0 0 10 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
                  stroke="currentColor"></path>
              </svg>
              <svg
                class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
                width="10"
                height="10"
                viewBox="0 0 10 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
                  stroke="currentColor"></path>
              </svg>
              <svg
                class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
                width="10"
                height="10"
                viewBox="0 0 10 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
                  stroke="currentColor"></path>
              </svg>
              <svg
                class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
                width="10"
                height="10"
                viewBox="0 0 10 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
                  stroke="currentColor"></path>
              </svg>
            </button>
          </div>
        </div>
        <div
          class="ml-auto max-w-[90px] md:order-1 md:col-start-2 md:ml-0 md:max-w-full md:items-end md:gap-0"
        >
          <svg
            class="w-full h-auto max-h-[290px] aspect-square footer--emblem object-bottom block"
            width="65"
            height="65"
            viewBox="0 0 65 65"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M39.13 43.55C39.13 41.0371 41.1671 39 43.68 39H47.45C49.9629 39 52 36.9629 52 34.45L52 4.55C52 2.03711 54.0371 4.3263e-06 56.55 4.54598e-06L60.45 4.88693e-06C62.9629 5.10662e-06 65 2.03711 65 4.55001V34.45C65 36.9629 62.9629 39 60.45 39H56.68C54.1671 39 52.13 41.0371 52.13 43.55L52.13 60.45C52.13 62.9629 50.0929 65 47.58 65L43.68 65C41.1671 65 39.13 62.9629 39.13 60.45L39.13 43.55Z"
              fill="currentColor"></path>
            <path
              d="M13.13 43.55C13.13 41.0371 15.1671 39 17.68 39H21.45C23.9629 39 26 36.9629 26 34.45L26 4.55C26 2.03711 28.0371 2.05331e-06 30.55 2.27299e-06L34.45 2.61394e-06C36.9629 2.83363e-06 39 2.03711 39 4.55L39 34.45C39 36.9629 36.9629 39 34.45 39H30.68C28.1671 39 26.13 41.0371 26.13 43.55L26.13 60.45C26.13 62.9629 24.0929 65 21.58 65H17.68C15.1671 65 13.13 62.9629 13.13 60.45L13.13 43.55Z"
              fill="currentColor"></path>
            <path
              d="M1.47744e-06 4.55C1.69713e-06 2.0371 2.03711 -2.19684e-07 4.55 0L8.45 3.40949e-07C10.9629 5.60633e-07 13 2.0371 13 4.55L13 21.45C13 23.9629 10.9629 26 8.45 26H4.55C2.0371 26 -2.19684e-07 23.9629 0 21.45L1.47744e-06 4.55Z"
              fill="currentColor"></path>
          </svg>
        </div>

        <nav
          class="order-1 col-span-2 flex flex-col gap-[32px] md:order-2 md:col-span-1 md:justify-end"
        >
          <ul class="flex flex-col gap-[4px]">
            <li>
              <a
                href="#projects"
                class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"
              >
                <div
                  class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"
                >
                </div>
                <div
                  class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"
                >
                  <span
                    class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full"
                  >
                    PROJECTS
                  </span>
                  <span
                    class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0"
                    aria-hidden="true"
                  >
                    PROJECTS
                  </span>
                </div>
              </a>
            </li>
            <li>
              <a
                href="#team"
                class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"
              >
                <div
                  class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"
                >
                </div>
                <div
                  class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"
                >
                  <span
                    class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full"
                  >
                    TEAM
                  </span>
                  <span
                    class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0"
                    aria-hidden="true"
                  >
                    TEAM
                  </span>
                </div>
              </a>
            </li>
            <li>
              <a
                href="#contact"
                class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"
              >
                <div
                  class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"
                >
                </div>
                <div
                  class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"
                >
                  <span
                    class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full"
                  >
                    Contact
                  </span>
                  <span
                    class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0"
                    aria-hidden="true"
                  >
                    Contact
                  </span>
                </div>
              </a>
            </li>
          </ul>

          <div class="hidden md:block">
            <p class="p3-mono text-rich-carbon/60">
              <span>Site by</span>
              <a
                class="group text-rich-carbon hover:text-rich-carbon transition-colors duration-400 ease-(--easing)"
                href="https://serieseight.com"
              >
                <span
                  class="relative isolate before:absolute before:-bottom-[2px] before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:bg-current before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover:before:scale-x-100"
                >
                  Series Eight
                </span>
              </a>
            </p>
            <p class="p3-mono text-rich-carbon/60">Copyright © 2026 CommandOSS</p>
          </div>
        </nav>
        <div
          class="contents flex-col items-end gap-[40px] md:order-3 md:flex md:justify-between"
        >
          <div class="order-3 flex w-full flex-col gap-[10px] md:order-1">
            <p class="p3-mono">From worldquant</p>
            <ul class="flex flex-col gap-[4px]">
              <li>
                <a
                  href="https://www.worldquantventures.com/"
                  class="group/button md:h7 h6 relative isolate flex items-center gap-[8px] uppercase"
                >
                  <div
                    class="bg-rich-carbon -mt-[3.5px] size-[16px] -translate-x-full rounded-[4px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"
                  >
                  </div>
                  <div
                    class="relative isolate flex -translate-x-[24px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"
                  >
                    <span
                      class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full"
                    >
                      Ventures
                    </span>
                    <span
                      class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0"
                      aria-hidden="true"
                    >
                      Ventures
                    </span>
                  </div>
                </a>
              </li>
              <li>
                <a
                  href="https://www.wqu.edu/"
                  class="group/button md:h7 h6 relative isolate flex items-center gap-[8px] uppercase"
                >
                  <div
                    class="bg-rich-carbon -mt-[3.5px] size-[16px] -translate-x-full rounded-[4px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"
                  >
                  </div>
                  <div
                    class="relative isolate flex -translate-x-[24px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"
                  >
                    <span
                      class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full"
                    >
                      University
                    </span>
                    <span
                      class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0"
                      aria-hidden="true"
                    >
                      University
                    </span>
                  </div>
                </a>
              </li>
            </ul>
          </div>
          <ul
            class="order-3 flex w-full max-w-[273px] flex-col items-start gap-[6px] md:order-2"
          >
            <li>
              <a
                class="group/button p2-mono"
                href="https://www.worldquantfoundry.com/legal/whistleblower-protection-statement"
              >
                <div
                  class="before:bg-rich-carbon relative isolate before:absolute before:bottom-0 before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover/button:before:scale-x-100"
                >
                  Whistleblower Protection Statement
                </div>
              </a>
            </li>
            <li>
              <a
                class="group/button p2-mono"
                href="https://www.worldquantfoundry.com/legal/privacy-policy"
              >
                <div
                  class="before:bg-rich-carbon relative isolate before:absolute before:bottom-0 before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover/button:before:scale-x-100"
                >
                  Privacy Policy
                </div>
              </a>
            </li>
            <li>
              <a
                class="group/button p2-mono"
                href="https://www.worldquantfoundry.com/legal/terms-and-conditions"
              >
                <div
                  class="before:bg-rich-carbon relative isolate before:absolute before:bottom-0 before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover/button:before:scale-x-100"
                >
                  Terms and Conditions
                </div>
              </a>
            </li>
            <li>
              <a
                class="group/button p2-mono"
                href="https://www.worldquantfoundry.com/legal/cookie-policy"
              >
                <div
                  class="before:bg-rich-carbon relative isolate before:absolute before:bottom-0 before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover/button:before:scale-x-100"
                >
                  Cookie Policy
                </div>
              </a>
            </li>
          </ul>
          <div
            class="text-rich-carbon/60 order-4 col-span-2 flex w-full max-w-[273px] flex-col gap-[6px] md:hidden"
          >
            <p class="p3-mono">
              <span class="text-rich-carbon/60">Site by</span>
              <a
                class="group text-rich-carbon transition-colors duration-400 ease-(--easing)"
                href="https://serieseight.com"
              >
                <span
                  class="before:bg-rich-carbon relative isolate before:absolute before:-bottom-[2px] before:left-0 before:h-px before:w-full before:origin-left before:scale-x-0 before:transition-[transform,scale] before:duration-400 before:ease-(--easing) group-hover:before:scale-x-100"
                >
                  Series Eight
                </span>
              </a>
            </p>
            <p class="p3-mono">Copyright © 2026 CommandOSS</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
