<header
  data-site-header
  class="layout--header group fixed top-0 isolate z-50 flex w-full items-center transition-transform duration-400 ease-(--easing) motion-reduce:duration-[0ms] lg:h-(--header-height) lg:overflow-hidden"
  :class="{ '-scrolled': scrolled, '-mobile-menu-open': mobileMenuOpen, '-translate-y-full': hidden }"
  x-data="{
		scrolled: false,
		hidden: false,
		lastScrollY: 0,
		windowHeight: window.innerHeight,
		mobileMenuOpen: false,
		scrollThreshold: 50,
		init() {
			window.addEventListener('scroll', () => {
				if (this.mobileMenuOpen) return;

				const currentScrollY = window.scrollY;
				const pastQuarterViewport = currentScrollY > this.windowHeight / 4;
				const pastFullViewport = currentScrollY > this.windowHeight;

				const scrollDelta = currentScrollY - this.lastScrollY;
				const scrollingDown = scrollDelta > this.scrollThreshold;
				const scrollingUp = scrollDelta < -this.scrollThreshold;

				this.scrolled = pastQuarterViewport;

				if (pastFullViewport) {
					if (scrollingDown) {
						this.hidden = true;
					} else if (scrollingUp) {
						this.hidden = false;
					}
				} else {
					this.hidden = false;
				}

				if (Math.abs(scrollDelta) > this.scrollThreshold) {
					this.lastScrollY = currentScrollY;
				}
			});

			this.$watch('mobileMenuOpen', (value) => {
				if (value) {
					smoother.paused(true);
				} else {
					smoother.paused(false);
				}
			});
		},
		scrollToLink(link) {
			this.mobileMenuOpen = false;
			smoother.scrollTo(link, true);
		},
		scrollToTop() {
			this.mobileMenuOpen = false;
			smoother.scrollTo(0, true);
		}
	}"
  @resize.window="windowHeight = window.innerHeight; if (mobileMenuOpen && !(window.innerWidth < 1024)) mobileMenuOpen = false"
>
  <div class="flex w-full lg:container">
    <div
      class="lg:group-[.-scrolled]:bg-urban-smoke group-[.-scrolled]:bg-rich-carbon group-[.-mobile-menu-open]:bg-rich-carbon relative isolate mx-auto flex h-(--header-height) w-fit grow items-center justify-between gap-[20px] bg-transparent px-[10px] transition-all duration-600 ease-(--easing) motion-reduce:duration-[0ms] lg:h-auto lg:px-0 lg:group-[.-scrolled]:w-fit lg:group-[.-scrolled]:grow-0 lg:group-[.-scrolled]:rounded-[8px] lg:group-[.-scrolled]:px-[12px] lg:group-[.-scrolled]:py-[4px]"
    >
      <a
