        :class="{ '-active md:w-[40%]!' : activeCard === 1 }"
        @mouseenter="activeCard = 1"
        @mouseleave="activeCard = null"
      >
        <div
          class="relative h-full w-full overflow-hidden rounded-[20px] transition-all delay-100 duration-500 ease-(--easing) md:w-[125%] md:group-[.-active]/card:w-full bg-rich-carbon text-neural-fog"
          id="ethos-card-1"
        >
          <div class="flex size-full justify-center pt-[40px] pb-[20px] md:py-[40px]">
            <div
              class="flex w-full flex-col items-center gap-[22px] px-[20px] text-center md:max-w-[300px] md:shrink-0 md:gap-[44px]"
            >
              <button
                class="hidden md:block"
                @click="activeCard = 1"
                :aria-expanded="(activeCard === 1).toString()"
                :aria-controls="`ethos-card-1`"
              >
                <h3
                  class="md:h5 h4 mx-auto max-w-[290px] uppercase"
                  x-data="splitTextReveal()"
                >
                  Forged, not hired
                </h3>
              </button>
              <h3 class="h4 md:h5 mx-auto max-w-[290px] uppercase md:hidden">
                Forged, not hired
