                  sizes="(min-width: 1400px) 1400px, calc(100vw - 32px)"
                />
                <img
                  class="size-full object-contain object-center"
                  src="https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077"
                  srcset="https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 200w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 400w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 600w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 900w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 1200w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 1500w,https://worldquant-foundry.files.svdcdn.com/production/images/exponential-foresight-icon.svg?dm=1763974077 2000w,"
                  sizes="(min-width: 1400px) 1400px, calc(100vw - 32px)"
                  width="2000"
                  height="2985.07"
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <div class="p2-mono flex flex-col gap-[15px]">
                <p>01 / 04</p>
                <p class="text-pretty">
                  Every engineer on the team has earned their seat by putting real work
                  on-chain.
                </p>
              </div>
            </div>
          </div>
        </div>
