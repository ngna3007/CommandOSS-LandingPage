---
---

<section
  class="bg-neural-fog text-rich-carbon overflow-hidden rounded-t-[20px] pt-[120px] pb-[200px] md:py-[220px]"
  x-data="{
		init() {
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (prefersReducedMotion) return;

			const tl = gsap.timeline({
				scrollTrigger: {
					trigger: this.$el,
					start: 'top bottom-=10%',
					end: 'top center',
					scrub: 1,
				}
			});

			tl.from(this.$el,
				{
					css: {
						clipPath: 'inset(0 100% 0 0)'
					},
					duration: 1.2,
				}
			)
		}
	}"
>
  <div class="container" x-ref="content" id="ethos">
    <div
      class="mb-[40px] grid grid-cols-1 gap-x-[24px] gap-y-[24px] md:mb-[60px] md:grid-cols-2"
    >
      <div class="flex flex-col gap-[12px]">
        <h2 class="p2-mono">Our ethos</h2>
        <p class="h5 uppercase">
          Vision matters.<br />
          Velocity wins.
        </p>
      </div>
      <div class="flex flex-col items-start">
        <p class="p1 border-rich-carbon/20 mb-[24px] border-t pt-[20px] md:mb-[32px]">
          We ship products across the Web3 and Web2 stack. Velocity at the core.
          Quality that holds.
        </p>

        <button
          class="group/button hover:animate-glitch-hover relative isolate motion-reduce:hover:animate-none"
          data-theme="dark"
          aria-label=""
          @click="$dispatch('contact-modal:open', '#contact')"
          x-data
        >
          <div class="flex h-[40px] items-center justify-center px-[20px]">
            <div
              class="group-data-[theme=light]/button:bg-neural-fog group-data-[theme=dark]/button:bg-rich-carbon motion-reduce:blur-0 button--dot size-[10px] -translate-x-[24px] rounded-[3px] opacity-0 blur-[20px] transition-all duration-400 ease-(--easing) group-hover/button:-translate-x-[5px] group-hover/button:opacity-100 group-hover/button:blur-[0px] group-active/button:-translate-x-[5px] group-active/button:opacity-100 group-active/button:blur-[0px] motion-reduce:hidden motion-reduce:translate-x-0 motion-reduce:opacity-0 motion-reduce:group-hover/button:translate-x-0 motion-reduce:group-hover/button:opacity-0"
            >
            </div>
            <div
              class="p2-mono group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon relative isolate flex -translate-x-[5px] overflow-hidden transition-transform duration-400 ease-(--easing) group-hover/button:translate-x-[5px] group-active/button:translate-x-[5px] motion-reduce:translate-x-0 motion-reduce:group-hover/button:translate-x-0"
            >
              <span
                class="transition-transform duration-400 ease-(--easing) group-hover/button:-translate-y-full group-active/button:-translate-y-full motion-reduce:translate-y-0 motion-reduce:group-hover/button:translate-y-0"
              >
                Join Us
              </span>
              <span
                class="absolute inset-0 translate-y-full transition-transform duration-400 ease-(--easing) group-hover/button:translate-y-0 group-active/button:translate-y-0 motion-reduce:hidden"
                aria-hidden="true"
              >
                Join Us
              </span>
            </div>
          </div>
          <svg
            class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
              stroke="currentColor"></path>
          </svg>
          <svg
            class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
              stroke="currentColor"></path>
          </svg>
          <svg
            class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
              stroke="currentColor"></path>
          </svg>
          <svg
            class="size-[9px] corner-accent transition-opacity ease-(--easing) duration-400 group-active/button:opacity-100 group-data-[theme=light]/button:text-neural-fog group-data-[theme=dark]/button:text-rich-carbon motion-reduce:opacity-100 motion-reduce:transition-none"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.499951 0.199996L0.499952 9.2M0.199951 0.499995L9.19995 0.499995"
              stroke="currentColor"></path>
          </svg>
        </button>
      </div>
    </div>
    <ul
      class="group flex flex-col gap-[20px] md:flex-row md:gap-0"
      id="ethos-cards"
      x-data="{
				activeCard: null,
				init() {
					const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					if (prefersReducedMotion) return;

					const mm = gsap.matchMedia();
					mm.add('(max-width: 767px)', () => {
						const cards = gsap.utils.toArray(this.$el.querySelectorAll('li'));
						cards.forEach((card) => {
							gsap.from(card, {
								scrollTrigger: {
									trigger: card,
									start: 'top 50%',
									end: 'bottom bottom',
								},
								clipPath: 'inset(0 0 100% 0)',
								duration: 0.6,
								ease: 'power3.inOut',
							});
						});
					});
				}
			}"
    >
      <li
        class="group/card w-full shrink-0 transition-[width] delay-100 duration-500 ease-(--easing) md:w-[25%] md:group-has-[li.-active]:w-[20%]"
        :class="{ '-active md:w-[40%]!' : activeCard === 1 }"
        @mouseenter="activeCard = 1"
        @mouseleave="activeCard = null"
      >
        <div
          class="relative h-full w-full min-h-[420px] overflow-hidden rounded-[20px] transition-all delay-100 duration-500 ease-(--easing) md:min-h-[500px] md:w-[125%] md:group-[.-active]/card:w-full text-neural-fog"
          id="ethos-card-1"
          style="background-image: url('/assets/bg-1.avif'); background-size: cover; background-position: center;"
        >
          <div class="relative flex size-full justify-between pt-[40px] pb-[20px] md:py-[40px]">
            <div
              class="flex w-full flex-col items-start gap-[22px] px-[20px] text-left md:max-w-[300px] md:shrink-0 md:gap-[44px]"
            >
              <button
                class="hidden text-left md:block"
                @click="activeCard = 1"
                :aria-expanded="(activeCard === 1).toString()"
                :aria-controls="`ethos-card-1`"
              >
                <h3 class="md:h5 h4 max-w-[290px] font-roc-grotesk font-black uppercase">Forged, not hired</h3>
              </button>
              <h3 class="h4 md:h5 max-w-[290px] font-roc-grotesk font-black uppercase md:hidden">Forged, not hired</h3>
              <div class="p2-mono mt-auto flex flex-col gap-[15px]">
                <p><span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">01 / 04</span></p>
                <p class="text-pretty">
                  <span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">Every engineer on the team has earned their seat by putting real work on-chain.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </li>

      <li
        class="group/card w-full shrink-0 transition-[width] delay-100 duration-500 ease-(--easing) md:w-[25%] md:group-has-[li.-active]:w-[20%]"
        :class="{ '-active md:w-[40%]!' : activeCard === 2 }"
        @mouseenter="activeCard = 2"
        @mouseleave="activeCard = null"
      >
        <div
          class="relative h-full w-full min-h-[420px] overflow-hidden rounded-[20px] transition-all delay-100 duration-500 ease-(--easing) md:min-h-[500px] md:w-[125%] md:group-[.-active]/card:w-full text-neural-fog"
          id="ethos-card-2"
          style="background-image: url('/assets/bg-2.avif'); background-size: cover; background-position: center;"
        >
          <div class="relative flex size-full justify-between pt-[40px] pb-[20px] md:py-[40px]">
            <div
              class="flex w-full flex-col items-start gap-[22px] px-[20px] text-left md:max-w-[300px] md:shrink-0 md:gap-[44px]"
            >
              <button
                class="hidden text-left md:block"
                @click="activeCard = 2"
                :aria-expanded="(activeCard === 2).toString()"
                :aria-controls="`ethos-card-2`"
              >
                <h3 class="md:h5 h4 max-w-[290px] font-roc-grotesk font-black uppercase">Hacker-house velocity</h3>
              </button>
              <h3 class="h4 md:h5 max-w-[290px] font-roc-grotesk font-black uppercase md:hidden">Hacker-house velocity</h3>
              <div class="p2-mono mt-auto flex flex-col gap-[15px]">
                <p><span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">02 / 04</span></p>
                <p class="text-pretty">
                  <span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">A co-located team in Ho Chi Minh City. Synchronous by default. Decisions made in the room, not across timezones.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </li>

      <li
        class="group/card w-full shrink-0 transition-[width] delay-100 duration-500 ease-(--easing) md:w-[25%] md:group-has-[li.-active]:w-[20%]"
        :class="{ '-active md:w-[40%]!' : activeCard === 3 }"
        @mouseenter="activeCard = 3"
        @mouseleave="activeCard = null"
      >
        <div
          class="relative h-full w-full min-h-[420px] overflow-hidden rounded-[20px] transition-all delay-100 duration-500 ease-(--easing) md:min-h-[500px] md:w-[125%] md:group-[.-active]/card:w-full text-neural-fog"
          id="ethos-card-3"
          style="background-color: #000; background-image: url('/assets/bg-3.png'); background-size: contain; background-position: center 90%; background-repeat: no-repeat;"
        >
          <div class="relative flex size-full justify-between pt-[40px] pb-[20px] md:py-[40px]">
            <div
              class="flex w-full flex-col items-start gap-[22px] px-[20px] text-left md:max-w-[300px] md:shrink-0 md:gap-[44px]"
            >
              <button
                class="hidden text-left md:block"
                @click="activeCard = 3"
                :aria-expanded="(activeCard === 3).toString()"
                :aria-controls="`ethos-card-3`"
              >
                <h3 class="md:h5 h4 max-w-[290px] font-roc-grotesk font-black uppercase">Direct Mysten collaboration</h3>
              </button>
              <h3 class="h4 md:h5 max-w-[290px] font-roc-grotesk font-black uppercase md:hidden">Direct Mysten collaboration</h3>
              <div class="p2-mono mt-auto flex flex-col gap-[15px]">
                <p><span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">03 / 04</span></p>
                <p class="text-pretty">
                  <span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">We build alongside the Mysten Labs core team — the engineers and researchers who build Sui itself.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </li>

      <li
        class="group/card w-full shrink-0 transition-[width] delay-100 duration-500 ease-(--easing) md:w-[25%] md:group-has-[li.-active]:w-[20%]"
        :class="{ '-active md:w-[40%]!' : activeCard === 4 }"
        @mouseenter="activeCard = 4"
        @mouseleave="activeCard = null"
      >
        <div
          class="relative h-full w-full min-h-[420px] overflow-hidden rounded-[20px] transition-all delay-100 duration-500 ease-(--easing) md:min-h-[500px] md:w-[125%] md:group-[.-active]/card:w-full text-neural-fog"
          id="ethos-card-4"
          style="background-image: url('/assets/bg-4.png'); background-size: cover; background-position: center; background-repeat: no-repeat;"
        >
          <div class="relative flex size-full justify-between pt-[40px] pb-[20px] md:py-[40px]">
            <div
              class="flex w-full flex-col items-start gap-[22px] px-[20px] text-left md:max-w-[300px] md:shrink-0 md:gap-[44px]"
            >
              <button
                class="hidden text-left md:block"
                @click="activeCard = 4"
                :aria-expanded="(activeCard === 4).toString()"
                :aria-controls="`ethos-card-4`"
              >
                <h3 class="md:h5 h4 max-w-[290px] font-roc-grotesk font-black uppercase">Open source by default</h3>
              </button>
              <h3 class="h4 md:h5 max-w-[290px] font-roc-grotesk font-black uppercase md:hidden">Open source by default</h3>
              <div class="p2-mono mt-auto flex flex-col gap-[15px]">
                <p><span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">04 / 04</span></p>
                <p class="text-pretty">
                  <span class="bg-rich-carbon text-neural-fog" style="border-radius: 12px; padding: 0.35em 0.75em; display: inline-block;">We publish repositories, document architecture, and contribute tooling back to the Sui ecosystem.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </li>
    </ul>
  </div>
</section>
