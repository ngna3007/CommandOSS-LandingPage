  <span
    class="text-off-white/60 p3-mono absolute bottom-[30px] left-1/2 -translate-x-1/2"
    x-data="{
			progress: 0,
			duration: 1400,
			startTime: null,
			easing: function(timeProgress) {
				const p1x = 0.62, p1y = 0.16;
				const p2x = 0.13, p2y = 1.01;

				// Calculate coefficients for the bezier curve
				const cx = 3 * p1x;
				const bx = 3 * (p2x - p1x) - cx;
				const ax = 1 - cx - bx;

				const cy = 3 * p1y;
				const by = 3 * (p2y - p1y) - cy;
				const ay = 1 - cy - by;

				let x = timeProgress;
				for (let i = 0; i < 4; i++) {
					const currentX = ((ax * x + bx) * x + cx) * x;
					const currentSlope = (3 * ax * x + 2 * bx) * x + cx;
					if (currentSlope === 0) break;
					x -= (currentX - timeProgress) / currentSlope;
				}

				return ((ay * x + by) * x + cy) * x;
			}
		}"
    x-init="
			document.body.style.overflow = 'hidden';

			startTime = Date.now();
			const animate = () => {
				const elapsed = Date.now() - startTime;
				const timeProgress = Math.min(elapsed / duration, 1);
				progress = Math.round(easing(timeProgress) * 100);

				if (timeProgress < 1) {
					requestAnimationFrame(animate);
				} else {
					document.body.style.overflow = '';
				}
			};
			requestAnimationFrame(animate);
		"
    x-text="progress + '%'"
  >
  </span>
