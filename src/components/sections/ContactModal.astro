<div
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
  aria-describedby="contact-modal-description"
  class="bg-rich-carbon/40 fixed inset-0 z-50 flex backdrop-blur-[10px]"
  x-data="{
		open: false,
		words: null,
		init() {
			const title = 'Ping CommandOSS.';
			
			this.words = title.split(' ');
			this.$watch('open', (value) => {
				if (value) {
					smoother.paused(true);
				} else {
					smoother.paused(false);
				}
			});

		},
		openContactModal(e) {
			this.open = true;
			for (const radio of this.$el.querySelectorAll('.fui-radio-input')) {
				if (radio.value.toLowerCase().trim() === e.detail.toLowerCase().trim()) {
					radio.checked = true;
				}
			}
		}
	}"
  @contact-modal:open.window="openContactModal($event)"
  x-trap.noscroll.noautofocus="open"
  x-show="open"
  x-cloak
  x-transition.opacity.duration.400ms
>
  <div
    class="bg-neural-fog text-rich-carbon modal--scrollbar relative isolate h-full w-full max-w-[700px] overflow-y-auto px-[16px] pt-[32px] md:rounded-r-[20px] md:p-[40px] md:pb-0"
    @click.outside="open = false"
    x-show="open"
    x-transition:enter="transition-[clip-path] ease-(--easing) duration-400 delay-100"
    x-transition:enter-start="[clip-path:inset(0_100%_0_0)]"
    x-transition:enter-end="[clip-path:inset(0_0_0_0)]"
    x-transition:leave="transition-[clip-path] ease-(--easing) duration-400"
    x-transition:leave-start="[clip-path:inset(0_0_0_0)]"
    x-transition:leave-end="[clip-path:inset(0_100%_0_0)]"
    dir="rtl"
  >
