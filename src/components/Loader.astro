    <div class="lo-cta"><span class="l_"><span class="l" data-cta>Enter</span></span></div>
    <div class="lo-exit">
      <span class="l_"><span class="l" data-exit>Authorized Access</span></span>
    </div>
    <div class="lo-circles">
      <svg viewBox="0 0 218 218" data-svg>
        <circle cx="109.323" cy="109.323" r="108.323" data-ring-outline></circle>
        <circle cx="109.323" cy="109.323" r="108.323" data-ring-progress></circle>
