    <div class="layer-slashes">
      <span data-slashes="//////////////////////////////////////////////////"
        >//////////////////////////////////////////////////</span
      >
    </div>
    <div class="layer-dots-l"><div></div><div></div><div></div><div></div></div>
    <div class="layer-dots-r"><div></div><div></div><div></div><div></div></div>
    <div class="layer-logo">
      <svg viewBox="0 0 435 435" xmlns="http://www.w3.org/2000/svg">
        <g fill="currentColor">
          <path
            d="M224.38 377.35 l0.13 -57.69 25.49 -0.25 c17.84 -0.17 26.08 -0.38 27.40 -0.76 9.47 -2.51 16.06 -6.07 22.26 -11.94 8.37 -7.94 13.51 -18.22 14.15 -28.33 l0.25 -3.95 10.45 -0.04 c5.73 0 22.60 -0.04 37.43 -0.08 l26.98 -0.08 0 22.30 c-0.04 21.03 -0.08 22.60 -0.93 27.40 -2.85 15.55 -8.79 28.38 -18.65 40.14 -13.89 16.52 -34.96 27.82 -57.09 30.54 -2.21 0.30 -16.14 0.47 -36.83 0.47 l-33.26 0 0 19.97 0 19.97 -8.92 0 -8.92 0 0.08 -57.65z"
          ></path>
          <path
            d="M117.25 394.39 c-25.06 -3.82 -47.28 -17.63 -60.96 -37.98 -5.86 -8.71 -9.64 -16.99 -12.06 -26.42 -2.51 -9.73 -2.59 -11.04 -2.59 -48.77 l0 -34.41 -20.82 0 -20.82 0 0 -8.71 0 -8.71 58.75 0.08 58.71 0.13 0.04 24.85 c0 26.76 0.04 27.36 2.38 34.20 4.50 13.08 15.55 23.96 28.97 28.46 6.75 2.25 7.77 2.34 33.64 2.34 l23.96 0 0 37.81 0 37.81 -42.57 -0.04 c-34.75 -0.04 -43.33 -0.17 -46.64 -0.64z"
          ></path>
          <path
            d="M41.63 167.71 c0 -39.76 0.04 -42.99 0.81 -48.13 2.85 -19.16 11 -35.47 24.64 -49.11 13.85 -13.85 31.18 -22.47 50.68 -25.23 3.53 -0.51 10.75 -0.64 37.85 -0.64 l33.43 0 0 -22.30 0 -22.30 8.71 0 8.71 0 0 60.11 0 60.11 -23.75 0 c-25.49 0 -27.06 0.08 -33.43 2.29 -13.04 4.42 -23.83 14.66 -28.67 27.19 -2.97 7.69 -3.06 8.41 -3.23 35.85 l-0.21 24.72 -37.77 0 -37.77 0 0 -42.57z"
          ></path>
          <path
            d="M313.80 162.79 c-0.81 -11.13 -6.03 -22.09 -14.36 -30.03 -5.90 -5.56 -11.94 -8.92 -20.77 -11.38 -3.06 -0.85 -4.25 -0.89 -28.76 -1.06 l-25.62 -0.13 0 -37.81 0 -37.77 42.31 0 c36.11 0 42.99 0.08 46.86 0.68 22.05 3.23 42.06 14.02 55.31 29.82 10.96 13.08 17.50 27.99 19.71 44.86 0.51 3.87 0.64 9.52 0.64 25.79 l0 20.77 -37.55 0 -37.55 0 -0.25 -3.74z"
          ></path>
        </g>
      </svg>
    </div>
    <div class="layer-top-right">
      <div class="layer-col"><div>3AEE 01 2000</div></div>
      <div class="layer-col"><div>HCMC GMT +7</div><div>10.776°N, 106.701°E</div></div>
      <div class="layer-col"><div>Sui Network</div><div>Mysten Labs</div></div>
      <div class="layer-col"><div>100101 00 011101 001</div></div>
    </div>
  </div>

  <!-- Top-left: 0 (counter) → Ready (swap on complete) -->
  <div class="cmdoss-loader__top">
    <div class="lo-nbr"><span class="l_"><span class="l" data-nbr>0</span></span></div>
    <div class="lo-ready"><span class="l_"><span class="l" data-ready>Ready</span></span></div>
  </div>

  <!-- Center: circles + logo/Enter/Authorized Access stacked -->
  <div class="cmdoss-loader__center" data-center style="pointer-events:none;">
    <div class="lo-logo" data-logo aria-hidden="true">
